{
    # Global options
    admin off
}

:5000 {
    # Proxy /offer requests to the Python WebRTC backend
    reverse_proxy /offer* backend:8080 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
    }

    # All other requests go to the React frontend
    reverse_proxy * frontend:3000 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
    }
}
